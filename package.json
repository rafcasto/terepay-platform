{
  "name": "tere-pay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "firebase:emulate": "firebase emulators:start --project terepay-dev --import=./emulator-data --export-on-exit",
    "firebase:emulate:clear": "firebase emulators:start --clear-on-exit",
    "firebase:export": "firebase emulators:export ./emulator-data",
    "seed:lender": "FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 ts-node --project tsconfig.scripts.json scripts/seed-lender.ts",
    "seed:lender:prod": "FIREBASE_AUTH_EMULATOR_HOST= FIRESTORE_EMULATOR_HOST= ts-node --project tsconfig.scripts.json scripts/seed-lender.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/flags": "^3.1.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "@opentelemetry/api": "^1.9.0",
    "firebase-admin": "^13.7.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
